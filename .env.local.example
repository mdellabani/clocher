# Repo-root .env.local — sourced by scripts/db-deploy.sh.
# Copy to .env.local and fill in. .env.local is gitignored.

# From https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Demo project (vdfyugekbtanrlveihlm)
# Connection string: Supabase dashboard → Project settings → Database → Connection string (URI)
# Use the "Session pooler" or "Transaction pooler" string — note: scripts run DDL so prefer Session pooler (port 5432) or direct.
SUPABASE_DB_URL_DEMO=
# Service role key: Project settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY_DEMO=

# Prod project (tsfmyrtmuravhzearntn)
SUPABASE_DB_URL_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
